POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "nome": "Maria",
  "email": "maria@nutri-responde.local",
  "senha": "123456",
  "tipo": "nutricionista",
  "telefone": "11999999999"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "maria@nutri-responde.local",
  "senha": "123456"
}

@baseUrl = http://localhost:3000
@id = 1

### Health check basico
GET {{baseUrl}}

### USUARIO - listar
GET {{baseUrl}}/usuario

### USUARIO - buscar por id
GET {{baseUrl}}/usuario/{{id}}

### USUARIO - criar
POST {{baseUrl}}/usuario
Content-Type: application/json

{
  "nome": "Rogher Soares",
  "email": "rogher@example.com",
  "senha_hash": "hash123",
  "tipo": "paciente",
  "telefone": "11999999999"
}

### USUARIO - atualizar
PATCH {{baseUrl}}/usuario/{{id}}
Content-Type: application/json

{
  "nome": "Rogher Soares Atualizado"
}

### USUARIO - remover
DELETE {{baseUrl}}/usuario/{{id}}

